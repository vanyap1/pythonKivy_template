	vcc5v0 {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0";
		regulator-min-microvolt = <0x4c4b40>;
		regulator-max-microvolt = <0x4c4b40>;
		phandle = <0x39>;
	};

	aliases {
		serial0 = "/soc/serial@1c28000";
	};

	leds {
		compatible = "gpio-leds";

		led-0 {
			label = "red_pwr";
			gpios = <0x38 0x00 0x0a 0x00>;
			#default-state = "on";
			linux,default-trigger = "heartbeat";
		};

		led-1 {
			label = "green_status";
			gpios = <0x0a 0x00 0x0a 0x00>;
			#default-state = "on";
			linux,default-trigger = "cpu";
		};
	};

	gpio-keys {
		compatible = "gpio-keys";

		key-0 {
			label = "k1";
			linux,code = <0x100>;
			gpios = <0x38 0x00 0x03 0x01>;
		};
	};

	vdd-cpux-regulator {
		compatible = "regulator-gpio";
		regulator-name = "vdd-cpux";
		regulator-min-microvolt = <0x10c8e0>;
		regulator-max-microvolt = <0x13d620>;
		regulator-always-on;
		regulator-boot-on;
		regulator-ramp-delay = <0x32>;
		enable-active-high;
		enable-gpios = <0x38 0x00 0x08 0x00>;
		gpios = <0x38 0x00 0x06 0x00>;
		gpios-states = <0x01>;
		states = <0x10c8e0 0x00 0x13d620 0x01>;
		phandle = <0x31>;
	};

	vcc-dram {
		compatible = "regulator-fixed";
		regulator-name = "vcc-dram";
		regulator-min-microvolt = <0x16e360>;
		regulator-max-microvolt = <0x16e360>;
		regulator-always-on;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x38 0x00 0x09 0x00>;
		vin-supply = <0x39>;
	};

	vdd-sys {
		compatible = "regulator-fixed";
		regulator-name = "vdd-sys";
		regulator-min-microvolt = <0x124f80>;
		regulator-max-microvolt = <0x124f80>;
		regulator-always-on;
		regulator-boot-on;
		enable-active-high;
		gpio = <0x38 0x00 0x08 0x00>;
		vin-supply = <0x39>;
	};

	pwrseq {
		compatible = "mmc-pwrseq-simple";
		reset-gpios = <0x38 0x00 0x07 0x01>;
		clocks = <0x11 0x01>;
		clock-names = "ext_clock";
		phandle = <0x0d>;
	};

	cvbs-connector {
		compatible = "composite-video-connector";

		port {

			endpoint {
				remote-endpoint = <0x3a>;
				phandle = <0x2f>;
			};
		};
	};
};
